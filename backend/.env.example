# SocialShield Backend Environment Variables
# Copy this to .env and fill in your values

# Firebase Service Account
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Google Safe Browsing API Key
# Get from: https://console.cloud.google.com → APIs → Safe Browsing API
GOOGLE_SAFE_BROWSING_API_KEY=YOUR_GOOGLE_SAFE_BROWSING_KEY_HERE

# VirusTotal API Key (free tier: 500 req/day)
# Get from: https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=YOUR_VIRUSTOTAL_KEY_HERE

# Model weights directory
MODEL_DIR=./ml/weights

# Redis for rate limiting (optional)
REDIS_URL=redis://localhost:6379

# Environment
ENV=production
DEBUG=false
