# SocialShield Backend Environment Variables Configuration

# Port to bind server
PORT=5000

# Secret key for signing JWT authorization tokens
JWT_SECRET=socialshield-super-secret-key-1337-prod-2026

# MongoDB Atlas connection string (leave blank to activate memory simulation)
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/socialshield?retryWrites=true&w=majority

# API Execution Environment (development/production)
FLASK_ENV=production
